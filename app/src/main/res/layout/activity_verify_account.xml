<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFF"
    tools:context=".VerifyAccountActivity">

    <!-- HEADER SECTION -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="40dp"
        android:paddingHorizontal="20dp"
        android:paddingBottom="16dp"
        android:background="#1E3A8A"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/next"
            android:rotation="180"
            app:tint="#FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvHeaderTitle"
            app:layout_constraintBottom_toBottomOf="@id/tvHeaderTitle"
            android:contentDescription="Quay lại" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xác minh tài khoản"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="40dp">

            <!-- LOGO SECTION -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginTop="60dp"
                app:cardCornerRadius="70dp"
                app:cardElevation="10dp"
                app:strokeColor="#1E40AF"
                app:strokeWidth="4dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#FFFFFF">
                    <TextView
                        android:id="@+id/tvLogoTT"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TT"
                        android:textSize="50sp"
                        android:textStyle="bold"
                        android:textColor="#1E40AF"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="20dp"
                        android:fontFamily="sans-serif-black" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SHOP"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_below="@id/tvLogoTT"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="-10dp" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="XÁC MINH DANH TÍNH"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1E40AF"
                android:layout_marginTop="20dp" />

            <TextView
                android:id="@+id/tvVerifyMsg"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:text="Nhập mật khẩu để xác nhận quyền truy cập vào tài khoản này"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEmail"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="320dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:hint="Email tài khoản"
                android:textColorHint="#444444"
                app:boxStrokeColor="#1E40AF"
                app:startIconDrawable="@android:drawable/ic_dialog_email"
                app:startIconTint="#1E40AF">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtVerifyEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:enabled="false"
                    android:textStyle="bold"
                    android:textColor="#000000" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="320dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Mật khẩu"
                android:textColorHint="#444444"
                app:passwordToggleEnabled="true"
                app:boxStrokeColor="#1E40AF"
                app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                app:startIconTint="#1E40AF">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtVerifyPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textStyle="bold"
                    android:textColor="#000000" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerify"
                android:layout_width="320dp"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:text="XÁC MINH TÀI KHOẢN"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1E40AF"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>