<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFF"
    tools:context=".CartActivity">

    <!-- ===== TOP BAR ===== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/topBarCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="#1E40AF"
                android:contentDescription="Quay lại" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Giỏ hàng"
                android:textColor="#1E293B"
                android:textSize="20sp"
                android:textStyle="bold" />

        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- ===== LIST VIEW (Sản phẩm trong giỏ) ===== -->
    <!-- layout_height="wrap_content" kết hợp với layout_constrainedHeight="true"
         để danh sách co giãn và đẩy phần dưới lên nếu ít item -->
    <ListView
        android:id="@+id/lvCartItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constrainedHeight="true"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:padding="12dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/topBarCard"
        app:layout_constraintBottom_toTopOf="@id/dividerRelated"
        app:layout_constraintVertical_bias="0.0" />

    <!-- ===== ĐƯỜNG GẠCH NGANG ===== -->
    <LinearLayout
        android:id="@+id/dividerRelated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/lvCartItems"
        app:layout_constraintBottom_toTopOf="@id/scrollRelated">

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#CBD5E1"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" SẢN PHẨM LIÊN QUAN "
            android:textColor="#64748B"
            android:textSize="12sp"
            android:textStyle="bold" />
        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#CBD5E1"/>
    </LinearLayout>

    <!-- ===== PHẦN SẢN PHẨM LIÊN QUAN (Xổ dọc 2 cột) ===== -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollRelated"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/dividerRelated"
        app:layout_constraintBottom_toTopOf="@id/bottomActionCard">

        <GridLayout
            android:id="@+id/gridRelated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:paddingHorizontal="8dp"
            android:alignmentMode="alignMargins">

            <!-- Các item liên quan (Mẫu) -->
            <include layout="@layout/item_related_small" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="wrap_content" />
            <include layout="@layout/item_related_small" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="wrap_content" />
            <include layout="@layout/item_related_small" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="wrap_content" />
            <include layout="@layout/item_related_small" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="wrap_content" />

        </GridLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ===== BOTTOM ACTION BAR (Màu trắng) ===== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomActionCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <CheckBox
                    android:id="@+id/chkSelectAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tất cả"
                    android:checked="true"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    app:buttonTint="#1E40AF" />

                <TextView
                    android:id="@+id/btnDeleteAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Xóa tất cả"
                    android:textColor="#EF4444"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPayment"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="2"
                android:text="THANH TOÁN"
                android:textStyle="bold"
                android:textSize="16sp"
                app:cornerRadius="12dp"
                app:backgroundTint="#1E40AF"
                android:textColor="#FFFFFF" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
