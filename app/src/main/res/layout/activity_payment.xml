<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFF"
    tools:context=".PaymentActivity">

    <!-- ===== TOP BAR ===== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/topBarCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="#1E40AF"
                android:contentDescription="Quay lại" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Thanh toán"
                android:textColor="#1E293B"
                android:textSize="20sp"
                android:textStyle="bold" />
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- ===== SCROLLABLE CONTENT ===== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBarCard"
        app:layout_constraintBottom_toTopOf="@id/bottomActionCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Địa chỉ giao hàng -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnToAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Địa chỉ giao hàng"
                        android:textStyle="bold"
                        android:textColor="#1E40AF"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/tvDisplayAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nguyễn Văn A | 0901234567\n123 Đường ABC, Phường 4, Quận 5, TP.HCM"
                        android:textColor="#1E293B"
                        android:layout_marginTop="8dp" />
                    <TextView
                        android:id="@+id/btnChangeAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thay đổi địa chỉ"
                        android:textColor="#1E40AF"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E2E8F0"
                android:layout_marginVertical="16dp" />

            <!-- Sản phẩm thanh toán -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProductSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp">
                    <ImageView
                        android:id="@+id/imgProduct"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/iphone15pro"
                        android:scaleType="fitCenter" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:id="@+id/tvProductName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="iPhone 15 Pro"
                            android:textStyle="bold"
                            android:textColor="#1E293B"
                            android:textSize="16sp" />
                        <TextView
                            android:id="@+id/tvProductDetail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Màu Titan Tự Nhiên, 256GB"
                            android:textColor="#64748B"
                            android:textSize="13sp"
                            android:maxLines="1"
                            android:ellipsize="end" />
                        <TextView
                            android:id="@+id/tvProductPrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="28.990.000đ"
                            android:textColor="#1E40AF"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="8dp"
                            android:background="#F1F5F9">
                            <TextView
                                android:id="@+id/btnMinus"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:text="-"
                                android:gravity="center"
                                android:textStyle="bold"
                                android:textColor="#000000" />
                            <TextView
                                android:id="@+id/tvQuantity"
                                android:layout_width="32dp"
                                android:layout_height="wrap_content"
                                android:text="1"
                                android:gravity="center"
                                android:textColor="#000000" />
                            <TextView
                                android:id="@+id/btnPlus"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:text="+"
                                android:gravity="center"
                                android:textStyle="bold"
                                android:textColor="#000000" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Khung dự kiến giao hàng -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#F0F9FF"
                app:strokeColor="#BAE6FD"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_dialog_info"
                        app:tint="#0284C7" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dự kiến giao hàng: 18 - 20 tháng 4"
                        android:textColor="#0369A1"
                        android:layout_marginStart="8dp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnOpenVoucher"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TT SHOP Voucher"
                        android:textStyle="bold"
                        android:textColor="#1E293B" />
                    <TextView
                        android:id="@+id/tvSelectedVoucherName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chọn mã giảm giá >"
                        android:textColor="#1E40AF"
                        android:layout_alignParentEnd="true" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Chi tiết thanh toán (PHẦN THIẾU CẦN FIX) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chi tiết thanh toán"
                        android:textStyle="bold"
                        android:textColor="#1E293B"
                        android:textSize="16sp"
                        android:layout_marginBottom="12dp"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tổng tiền hàng"
                            android:textColor="#64748B" />
                        <TextView
                            android:id="@+id/tvSubtotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="0đ"
                            android:textColor="#1E293B" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phí vận chuyển"
                            android:textColor="#64748B" />
                        <TextView
                            android:id="@+id/tvShipping"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="0đ"
                            android:textColor="#1E293B" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Giảm giá voucher"
                            android:textColor="#64748B" />
                        <TextView
                            android:id="@+id/tvDiscount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="-0đ"
                            android:textColor="#E11D48" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F1F5F9"
                        android:layout_marginVertical="8dp" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tổng thanh toán"
                            android:textStyle="bold"
                            android:textColor="#1E293B"
                            android:textSize="16sp"/>
                        <TextView
                            android:id="@+id/tvFinalTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="0đ"
                            android:textStyle="bold"
                            android:textColor="#1E40AF"
                            android:textSize="18sp" />
                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ===== BOTTOM ACTION BAR ===== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomActionCard"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:cardElevation="24dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp">
            <TextView
                android:id="@+id/tvTotalItems"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng (1 mặt hàng)"
                android:textColor="#64748B"
                android:layout_marginTop="12dp" />
            <TextView
                android:id="@+id/tvTotalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="28.990.000đ"
                android:textColor="#1E40AF"
                android:textStyle="bold"
                android:textSize="20sp"
                android:layout_below="@id/tvTotalItems" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOrder"
                android:layout_width="160dp"
                android:layout_height="60dp"
                android:text="ĐẶT HÀNG"
                android:textStyle="bold"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                app:cornerRadius="12dp"
                app:backgroundTint="#1E40AF" />
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
