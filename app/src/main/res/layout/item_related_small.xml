<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="120dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeColor="#F1F5F9"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <ImageView
            android:id="@+id/imgRelated"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:src="@drawable/phone_mockup"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/tvRelatedName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="iPhone 15"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvRelatedPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="22.990.000đ"
            android:textSize="12sp"
            android:textColor="#1E40AF"
            android:textStyle="bold" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
