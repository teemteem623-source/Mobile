<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF">

    <ImageView
        android:id="@+id/imgBannerItem"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:src="@drawable/phone_mockup"
        android:background="#FFFFFF" />

    <!-- Xóa bỏ lớp phủ đen, thay bằng một dải trắng mờ ở dưới để hiện text -->
    <TextView
        android:id="@+id/tvBannerTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:text="Siêu ưu đãi tháng này"
        android:textColor="#1E40AF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="12dp"
        android:background="#B3FFFFFF"/>

</com.google.android.material.card.MaterialCardView>
